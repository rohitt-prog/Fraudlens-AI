# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tosca/
.pytest_cache/
.unittest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production
.venv
venv
ENV/
env/

# IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Data and models (project specific)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep
models/*
!models/.gitkeep
logs/*
!logs/.gitkeep
mlruns/*
!mlruns/.gitkeep

# Jupyter Notebooks checkpoint / cache
.ipynb_checkpoints
*/.ipynb_checkpoints/*
