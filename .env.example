# ==============================================================================
# FraudLens AI - Environment Configuration Example
# Copy this file to '.env' and modify the values for local development.
# ==============================================================================

# Project Metadata
PROJECT_NAME="FraudLens AI"
VERSION="0.1.0"
ENV="development"
RANDOM_SEED=42

# Logging Configuration
LOG_LEVEL="INFO"

# API Configuration
API_HOST="0.0.0.0"
API_PORT=8000
API_DEBUG=True

# Dashboard Configuration
DASHBOARD_HOST="localhost"
DASHBOARD_PORT=3000
